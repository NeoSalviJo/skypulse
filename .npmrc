# Prevent Windows failures where Node truncates nested .pnpm paths (e.g. "Cannot find module …\vit")
# while resolving vite from Tailwind/Vite loaders.
node-linker=hoisted

# Still broken? Enable Windows long paths (Group Policy “Enable Win32 long paths” /
# HKLM\...\FileSystem LongPathsEnabled=1), or clone to a shorter path like C:\dev\skypulse.